# Discord Bot Credentials
DISCORD_TOKEN="YOUR_BOT_TOKEN_HERE"
CLIENT_ID="YOUR_CLIENT_ID_HERE"
GUILD_ID="YOUR_GUILD_ID_HERE"
# Supabase Config
SUPABASE_URL="YOUR_SUPABASE_URL_HERE"
SUPABASE_KEY="YOUR_SUPABASE_ANON_KEY_HERE"

# Sentry Config (Optional error and log monitoring)
SENTRY_DSN="YOUR_SENTRY_DSN_HERE"
NODE_ENV="development"

# Groq API Config (For AI Agent and plugins)
GROQ_API_KEY="YOUR_GROQ_API_KEY_HERE"
GROQ_MODEL="llama-3.1-8b-instant"

# Music / yt-dlp Cookies Config (Optional path to netscape-format cookies.txt)
YTDLP_COOKIES_PATH="./cookies.txt"

# Bot Owner ID Configuration
OWNER_ID="YOUR_OWNER_ID_HERE"

# Bot Log Language Configuration (en / id)
BOT_LANGUAGE="en"
